<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>UIAppFonts</key>
	<array>
		<string>Jost-900-Black.ttf</string>
		<string>Jost-700-Bold.ttf</string>
		<string>Jost-500-Medium.ttf</string>
	</array>
	<!-- Injected at build time from Config.xcconfig's REVENUECAT_API_KEY via
	     Xcode's Info.plist build-setting expansion (INFOPLIST_EXPAND_BUILD_SETTINGS,
	     on by default). A custom key like this is NOT merged by the
	     INFOPLIST_KEY_* mechanism — that only covers Apple-defined keys — so it
	     must live in the physical Info.plist as a $() reference. Read back via
	     ImageCleanerApp.revenueCatAPIKey(). Empty on a clone without Config.xcconfig. -->
	<key>RevenueCatAPIKey</key>
	<string>$(REVENUECAT_API_KEY)</string>
</dict>
</plist>
